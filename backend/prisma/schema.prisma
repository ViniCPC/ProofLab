// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  RESEARCHER
  FUNDER
  ADMIN
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  CANCELLED
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  PENDING_REVIEW
  SUBMITTED
  APPROVED
  REJECTED
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String?
  walletAddress String   @unique
  role          UserRole @default(FUNDER)
  reputation    Float    @default(0)
  createdAt     DateTime @default(now())

  projects      ResearchProject[]
  contributions Contribution[]
  votes         Vote[]
}

model ResearchProject {
  id               String        @id @default(uuid())
  title            String
  description      String
  totalAmount      Decimal       @db.Decimal(18, 6) // compatível com USDC
  aiSummary        String?
  innovationScore  Int?
  feasibilityScore Int?
  riskLevel        String?
  complexityLevel  String?
  status           ProjectStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  onChainProjectNonce   BigInt? // u64 seed usado no PDA Solana
  onChainProjectAddress String? // PDA base58 do projeto
  escrowVaultAddress    String? // PDA base58 do vault de escrow
  onChainStatus         String? // "Funding" | "Active" | "Completed" | "Cancelled"

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  milestones    Milestone[]
  contributions Contribution[]
}

model Milestone {
  id                 String          @id @default(uuid())
  title              String
  description        String
  amount             Decimal         @db.Decimal(18, 6)
  order              Int
  status             MilestoneStatus @default(PENDING)
  aiSummary          String?
  consistencyScore   Int?
  completionEstimate Int?
  aiRiskLevel        String?
  submittedReport    String?
  submittedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  onChainMilestoneAddress String? // PDA base58 do milestone
  releaseTransactionHash  String? // assinatura da tx de release_funds

  projectId String
  project   ResearchProject @relation(fields: [projectId], references: [id])

  votes Vote[]

  @@unique([projectId, order]) // ordem única por projeto
}

model Contribution {
  id        String   @id @default(uuid())
  amount    Decimal  @db.Decimal(18, 6)
  createdAt DateTime @default(now())


  transactionHash            String? // assinatura da tx de fund_project
  onChainContributionAddress String? // PDA base58 da contribution

  wallet String
  funder User   @relation(fields: [wallet], references: [walletAddress])

  projectId String
  project   ResearchProject @relation(fields: [projectId], references: [id])

  @@unique([wallet, projectId]) // um registro por funder por projeto
}

model Vote {
  id        String   @id @default(uuid())
  approve   Boolean
  createdAt DateTime @default(now())

  voterWallet String
  voter       User   @relation(fields: [voterWallet], references: [walletAddress])

  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id])

  @@unique([voterWallet, milestoneId]) // um voto por wallet por milestone
}
